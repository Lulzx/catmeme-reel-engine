  ],
  "beats": [
    {
      "action": "*i speak in the meeting... so does the echo*",
      "bg": { "place": "office" },
      "cast": [ { "name": "ME", "want": ["talking", "confident", "explaining", "serious"], "size": 0.5 } ]
    },
    {
      "action": "*\"someone has an echo\" — me: someone has an echo*",
      "bg": { "place": "office" },
      "cast": [ { "name": "ME", "want": ["awkward", "sheepish", "bashful", "uneasy"], "size": 0.5 } ]
    },
    {
      "action": "*the muting séance begins, one by one*",
      "bg": { "place": "office" },
      "cast": [ { "name": "ME", "want": ["watching", "alert", "waiting", "curious"], "size": 0.5 } ]
    },
    {
      "action": "*it's me. it was always me*",
      "bg": { "place": "office" },
      "cast": [ { "name": "ME", "want": ["guilty", "ashamed", "remorseful", "droopy"], "size": 0.5 } ]
    },
    {
      "action": "*me apologizing. my echo apologizing too*",
      "bg": { "place": "office" },
      "cast": [
        { "name": "ME", "want": ["embarrassed", "flustered", "cringing", "awkward"], "size": 0.4, "pos": 0.30 },
        { "name": "ECHO", "want": ["mocking", "laughing", "copying", "amused"], "size": 0.4, "pos": 0.70, "flip": true }
      ]
    },
    {
      "action": "*brain fully short-circuiting on mute duty*",
      "bg": { "place": "office" },
      "cast": [ { "name": "ME", "want": ["spinning", "brainrot", "short-circuit", "dizzy"], "size": 0.5 } ]
