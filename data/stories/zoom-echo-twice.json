{
  "title": "Your Echo Is In The Meeting And Everyone Hears You Twice",
  "output": "zoom-echo-twice.mp4",
  "canvas": { "w": 1080, "h": 1920, "fps": 30 },
  "max_beat_dur": 4.5,
  "baseline": 0.9,
  "pov": "POV: your echo is in the meeting and everyone hears you twice",
  "outro": "FOLLOW FOR DAILY POVS",
  "outro_cast": [
