    {
      "action": "*a tiny voice: \"just use headphones\"*",
      "bg": { "place": "office" },
      "cast": [ { "name": "COWORKER", "want": ["tiny", "piping-up", "small-voice", "interjecting"], "size": 0.5 } ]
    },
    {
      "action": "*rejoin on phone. now there are two of me*",
      "bg": { "place": "office" },
      "cast": [ { "name": "ME", "want": ["deadpan", "resigned", "defeated", "done"], "size": 0.5 } ],
      "dur": 6.0
    }
  ]
