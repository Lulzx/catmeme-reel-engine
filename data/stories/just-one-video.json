    {
      "action": "*one video becomes three hours of scrolling*",
      "bg": { "img": "dark bedroom phone glow night", "palette": "bedroom" },
      "cast": [ { "name": "ME", "want": ["doomscrolling", "scrolling", "bored", "zoning-out"], "size": 0.5 } ]
    },
    {
      "action": "*I find one comment that ENRAGES me*",
      "bg": { "img": "dark bedroom phone glow night", "palette": "rage" },
