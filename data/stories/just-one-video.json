    },
    {
      "action": "*typing a 6-paragraph reply to a stranger*",
      "bg": { "img": "person typing laptop keyboard closeup", "palette": "brain" },
      "cast": [ { "name": "ME", "want": ["typing", "busy", "panic-work", "working"], "size": 0.48 } ]
    },
    {
      "action": "*I delete it and stare into the void*",
      "bg": { "img": "dark starry night sky space", "palette": "void" },
      "cast": [ { "name": "ME", "want": ["zoning-out", "dead-inside", "blank", "exhausted"], "size": 0.48 } ]
