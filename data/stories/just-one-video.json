    {
      "action": "*snacking while the drama unfolds*",
      "bg": { "img": "dark bedroom cozy night interior", "palette": "snack" },
      "cast": [ { "name": "ME", "want": ["eating", "snacking", "munching", "hungry"], "size": 0.5 } ]
