    {
      "action": "*the sun comes up. I have not slept.*",
      "bg": { "img": "sunrise window bedroom morning light", "palette": "dawn" },
      "dur": 5.0,
      "cast": [ { "name": "ME", "want": ["exhausted", "resigned", "dead-inside", "tired"], "size": 0.5 } ]
    },
    {
      "action": "*my alarm for the gym goes off*",
      "bg": { "img": "bright bedroom morning alarm clock", "palette": "alarm" },
      "cast": [ { "name": "ME", "want": ["screaming", "yelling", "outburst", "frantic"], "size": 0.52 } ]
